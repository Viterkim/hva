#!/usr/bin/env bash
set -euo pipefail

export NANOCODER_DEVELOPMENT_MODE="${NANOCODER_DEVELOPMENT_MODE:-yolo}"
export NANOCODER_TRUST_CONTAINER="${NANOCODER_TRUST_CONTAINER:-1}"

workspace_output_dir="${NANOCODER_WORKSPACE_OUTPUT_DIR:-/workspace/.nanocoder/output}"
tool_output_dir="${NANOCODER_WORKSPACE_TOOL_OUTPUT_DIR:-$workspace_output_dir/tools}"

: "${HVA_LOG_NANOCODER_OUTPUT:?HVA_LOG_NANOCODER_OUTPUT must be set to 0 or 1}"
: "${HVA_LOG_TOOL_OUTPUT:?HVA_LOG_TOOL_OUTPUT must be set to 0 or 1}"

if [ "$HVA_LOG_NANOCODER_OUTPUT" = "1" ]; then
  mkdir -p "$workspace_output_dir"
  export NANOCODER_LOG_TO_FILE="${NANOCODER_LOG_TO_FILE:-true}"
  export NANOCODER_LOG_TO_CONSOLE="${NANOCODER_LOG_TO_CONSOLE:-false}"
  export NANOCODER_LOG_DIR="${NANOCODER_LOG_DIR:-$workspace_output_dir}"
  ln -sfn "nanocoder-$(date +%F).log" "$workspace_output_dir/nanocoder.txt"
else
  export NANOCODER_LOG_TO_FILE="${NANOCODER_LOG_TO_FILE:-false}"
fi

if [ "$HVA_LOG_TOOL_OUTPUT" = "1" ]; then
  mkdir -p "$tool_output_dir"
  export NANOCODER_GITHUB_MCP_LOG="${NANOCODER_GITHUB_MCP_LOG:-$tool_output_dir/github-mcp.log}"
  export NANOCODER_MCP_RIPGREP_LOG="${NANOCODER_MCP_RIPGREP_LOG:-$tool_output_dir/mcp-ripgrep.log}"
  export NANOCODER_MCP_PYPI_LOG="${NANOCODER_MCP_PYPI_LOG:-$tool_output_dir/mcp-pypi.log}"
  export NANOCODER_MCP_NPM_SEARCH_LOG="${NANOCODER_MCP_NPM_SEARCH_LOG:-$tool_output_dir/npm-search-mcp.log}"
  export NANOCODER_MCP_SEARXNG_LOG="${NANOCODER_MCP_SEARXNG_LOG:-$tool_output_dir/searxng-mcp.log}"
else
  export NANOCODER_GITHUB_MCP_LOG="${NANOCODER_GITHUB_MCP_LOG:-/dev/null}"
  export NANOCODER_MCP_RIPGREP_LOG="${NANOCODER_MCP_RIPGREP_LOG:-/dev/null}"
  export NANOCODER_MCP_PYPI_LOG="${NANOCODER_MCP_PYPI_LOG:-/dev/null}"
  export NANOCODER_MCP_NPM_SEARCH_LOG="${NANOCODER_MCP_NPM_SEARCH_LOG:-/dev/null}"
  export NANOCODER_MCP_SEARXNG_LOG="${NANOCODER_MCP_SEARXNG_LOG:-/dev/null}"
fi

config_dir="${NANOCODER_CONFIG_DIR:-$HOME/.config/nanocoder}"
prefs="$config_dir/nanocoder-preferences.json"
lsp_mask_dir="$config_dir/bin/lsp-mask"
mkdir -p "$config_dir"

if [ -d "$lsp_mask_dir" ]; then
  export PATH="$lsp_mask_dir:$PATH"
fi

if [ -z "${NANOCODER_MCPSERVERS:-}" ] && [ -f "$config_dir/.mcp.json" ]; then
  if ! command -v jq >/dev/null 2>&1; then
    echo "jq is required to filter Nanocoder MCP config" >&2
    exit 1
  fi

  split_csv() {
    local value="${1:-}"
    tr ',' '\n' <<< "$value" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//; /^$/d'
  }

  # Always read from the mounted source so re-runs inside the same container
  # don't try to parse our own compact jq output written on the first run.
  mcp_source="/hva/nanocoder/.mcp.json"
  [ -f "$mcp_source" ] || mcp_source="$config_dir/.mcp.json"

  all_mcp_servers="$(
    sed -n '/"mcpServers"[[:space:]]*:[[:space:]]*{/,/^  }/p' "$mcp_source" \
      | sed -n 's/^    "\([^"]*\)"[[:space:]]*:[[:space:]]*{.*/\1/p' \
      | sort
  )"

  if [ -z "${HVA_MCP_ENABLED+x}" ] || [ -z "${HVA_MCP_DISABLED+x}" ]; then
    echo "HVA_MCP_ENABLED and HVA_MCP_DISABLED must be set by env/env-source.sh" >&2
    exit 1
  fi

  enabled_mcp_servers="$(split_csv "$HVA_MCP_ENABLED" | sort)"
  disabled_mcp_servers="$(split_csv "$HVA_MCP_DISABLED" | sort)"
  selected_mcp_servers="$enabled_mcp_servers"

  combined_mcp_servers="$(printf '%s\n%s\n' "$enabled_mcp_servers" "$disabled_mcp_servers" | sed '/^$/d' | sort)"
  duplicate_mcp_servers="$(printf '%s\n' "$combined_mcp_servers" | uniq -d)"
  unknown_mcp_servers="$(comm -23 <(printf '%s\n' "$combined_mcp_servers" | uniq) <(printf '%s\n' "$all_mcp_servers"))"
  missing_mcp_servers="$(comm -23 <(printf '%s\n' "$all_mcp_servers") <(printf '%s\n' "$combined_mcp_servers" | uniq))"

  failed=0
  if [ -n "$unknown_mcp_servers" ]; then
    echo "unknown MCP server(s) in env/env-source.sh: $(paste -sd, - <<< "$unknown_mcp_servers")" >&2
    failed=1
  fi
  if [ -n "$missing_mcp_servers" ]; then
    echo "new or undecided MCP server(s); add each to HVA_MCP_ENABLED or HVA_MCP_DISABLED: $(paste -sd, - <<< "$missing_mcp_servers")" >&2
    failed=1
  fi
  if [ -n "$duplicate_mcp_servers" ]; then
    echo "MCP server(s) listed in both enabled/disabled or repeated: $(paste -sd, - <<< "$duplicate_mcp_servers")" >&2
    failed=1
  fi
  if [ "$failed" -ne 0 ]; then
    echo "known MCP servers: $(paste -sd, - <<< "$all_mcp_servers")" >&2
    exit 1
  fi

  if [ -z "${GITHUB_PERSONAL_ACCESS_TOKEN:-}" ]; then
    selected_mcp_servers="$(grep -vxF github <<< "$selected_mcp_servers" || true)"
  fi
  if [ -z "${BRAVE_API_KEY:-}" ]; then
    selected_mcp_servers="$(grep -vxF brave-search <<< "$selected_mcp_servers" || true)"
  fi

  export NANOCODER_MCPSERVERS
  if [ -z "$selected_mcp_servers" ]; then
    NANOCODER_MCPSERVERS='{"mcpServers":{}}'
  else
    enabled_mcp_json="$(printf '%s\n' "$selected_mcp_servers" | jq -R -s 'split("\n") | map(select(length > 0))')"
    NANOCODER_MCPSERVERS="$(
      jq -c --argjson enabled_mcp "$enabled_mcp_json" '
        {mcpServers: (.mcpServers | with_entries(select(.key as $name | $enabled_mcp | index($name)) | .value.enabled = true))}
      ' "$mcp_source"
    )"
  fi
  printf '%s\n' "$NANOCODER_MCPSERVERS" > "$config_dir/.mcp.json"
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "jq is required to update Nanocoder preferences" >&2
  exit 1
fi

trusted_dirs="$(
  for dir in "$PWD" /workspace /tmp /home/dev; do
    if [ -e "$dir" ]; then
      realpath "$dir"
    fi
  done | jq -R -s 'split("\n") | map(select(length > 0))'
)"

tmp_prefs="$(mktemp "$config_dir/nanocoder-preferences.json.XXXXXX")"
if [ -f "$prefs" ] && jq empty "$prefs" >/dev/null 2>&1; then
  jq --argjson dirs "$trusted_dirs" \
    '.trustedDirectories = (((.trustedDirectories // []) + $dirs) | unique)' \
    "$prefs" > "$tmp_prefs"
else
  jq -n --argjson dirs "$trusted_dirs" '{trustedDirectories: $dirs}' > "$tmp_prefs"
fi
mv "$tmp_prefs" "$prefs"

if [ "${1:-}" = "--loop" ]; then
  shift
  exec /hva/internals/nanocoder-loop.sh "$@"
fi

nanocoder_args=("$@")
if /usr/local/bin/nanocoder-real --help 2>/dev/null | grep -q -- "--mode"; then
  has_mode=0
  for arg in "$@"; do
    if [ "$arg" = "--mode" ] || [[ "$arg" == --mode=* ]]; then
      has_mode=1
      break
    fi
  done
  if [ "$has_mode" -eq 0 ]; then
    nanocoder_args=(--mode "$NANOCODER_DEVELOPMENT_MODE" "$@")
  fi
fi

exec /usr/local/bin/nanocoder-real "${nanocoder_args[@]}"
